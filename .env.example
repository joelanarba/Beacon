ENVIRONMENT=development
SECRET_KEY=change-me-to-a-strong-random-value-at-least-32-chars

POSTGRES_USER=beacon
POSTGRES_PASSWORD=beacon
POSTGRES_DB=beacon
DATABASE_URL=postgresql+asyncpg://beacon:beacon@postgres:5432/beacon

REDIS_URL=redis://redis:6379

RABBITMQ_USER=beacon
RABBITMQ_PASSWORD=beacon
AMQP_URL=amqp://beacon:beacon@rabbitmq:5672/

GRAFANA_PASSWORD=admin

DOCS_ENABLED=true
SIMULATOR_ENABLED=true
METRICS_PUBLIC=true
CORS_ALLOWED_ORIGINS=
INGEST_SHARED_SECRET=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Copy to .env and fill in. Never commit .env.

ENVIRONMENT=development
SECRET_KEY=generate-with-openssl-rand-hex-32

# Postgres
POSTGRES_USER=beacon
POSTGRES_PASSWORD=beacon
POSTGRES_DB=beacon
DATABASE_URL=postgresql+asyncpg://beacon:beacon@postgres:5432/beacon

# Redis (GEO + USSD session state)
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_USER=beacon
RABBITMQ_PASSWORD=beacon
AMQP_URL=amqp://beacon:beacon@rabbitmq:5672/

# Matching
RESPONDER_SEARCH_RADIUS_M=5000
RESPONDER_MAX_RADIUS_M=25000

# USSD session
USSD_SESSION_TTL_SECONDS=120

# Grafana
GRAFANA_PASSWORD=admin

PYTHONASYNCIODEBUG=1
